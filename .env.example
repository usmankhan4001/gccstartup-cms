# ── Payload / Next ──
DATABASE_URI=postgres://gcc:gcc@postgres:5432/gccstartup
PAYLOAD_SECRET=change-me-to-a-long-random-string
# Comma-separated origins allowed to call the API / submit the form
ALLOWED_ORIGINS=https://gccstartup.com,http://localhost:3000
# Where uploaded media is stored (mount a Dokploy volume here)
MEDIA_DIR=/app/media

# ── Twenty CRM ──
TWENTY_BASE_URL=https://api.twenty.com
TWENTY_API_KEY=

# ── WAHA (WhatsApp HTTP API) ──
WAHA_BASE_URL=http://waha:3000
WAHA_SESSION=default
WAHA_API_KEY=

# ── Notifications ──
ADMIN_WHATSAPP=9715xxxxxxxx
NOTIFY_LEAD=true

# ── n8n (human-like WhatsApp flow) ──
# When set, leads are forwarded here instead of WAHA being called directly.
# n8n runs: start typing → dynamic wait → stop typing → send (see n8n/gcc-lead-whatsapp.json)
N8N_WEBHOOK_URL=
